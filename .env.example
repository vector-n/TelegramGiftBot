# ================================================================
#   TELEGRAM GIFT BOT — CONFIGURATION
#   Rename this file to .env and fill in your values.
# ================================================================

# ── Telegram Bot (from @BotFather) ───────────────────────────
BOT_TOKEN=your_bot_token_here

# ── Telegram User Session (from my.telegram.org/apps) ────────
API_ID=your_api_id_here
API_HASH=your_api_hash_here
PHONE_NUMBER=+966501234567

# ── Groq AI (free — from console.groq.com) ───────────────────
GROQ_API_KEY=your_groq_api_key_here
# Best free model. Change only if Groq releases a better one.
GROQ_MODEL=llama-3.3-70b-versatile

# ── Your Telegram User ID (admin) ────────────────────────────
# Send /start to @userinfobot on Telegram to get your ID.
ADMIN_ID=your_telegram_user_id_here

# ── Channels ─────────────────────────────────────────────────
# Where the bot posts. Use @username or numeric ID. Comma-separated.
TARGET_CHANNELS=@your_channel_here

# Channels to monitor for new content. Comma-separated.
SOURCE_CHANNELS=@source_channel_1,@source_channel_2

# ── Posting settings ─────────────────────────────────────────
# Minutes between automatic posts (can be changed live with /setdelay)
POST_DELAY_MINUTES=30

# true  → bot posts automatically on schedule
# false → bot only posts when you use /postnow or the inline button
AUTO_POST=true

# true  → every new post requires /approve before it's published
# false → posts go straight to the "approved" queue (default)
REQUIRE_APPROVAL=false

# ── Media ────────────────────────────────────────────────────
# Max file size in MB to download and repost (Bot API limit is 50 MB)
MAX_MEDIA_MB=50

# ── Timezone (for daily summary schedule) ────────────────────
TIMEZONE=Asia/Riyadh

# Hour (24h) to auto-post the daily summary (0–23)
SUMMARY_HOUR=20

# ── Storage paths (usually no need to change) ────────────────
DB_PATH=bot_data.db
MEDIA_DIR=media_cache
SESSION_NAME=user_session
